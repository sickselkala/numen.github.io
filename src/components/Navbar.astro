---
// src/components/Navbar.astro
---

<header class="fixed top-0 inset-x-0 z-50 bg-black/60 backdrop-blur-xl border-b border-white/5 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <a href="/" class="flex-shrink-0 group">
        <span class="text-white font-display font-bold text-2xl tracking-tighter uppercase group-hover:text-zinc-300 transition-colors">
          Numen <span class="text-xs font-mono text-zinc-500 tracking-widest ml-1">APS</span>
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-8">
        <a href="/chi-siamo" class="text-sm font-medium text-zinc-400 hover:text-white uppercase tracking-wider transition-colors">Chi Siamo</a>
        <a href="/eventi" class="text-sm font-medium text-zinc-400 hover:text-white uppercase tracking-wider transition-colors">Eventi</a>
        <a href="/matenano-kings-cup" class="text-sm font-medium text-zinc-400 hover:text-white uppercase tracking-wider transition-colors">MKC</a>        
        <div class="relative group pt-8 pb-8 -my-8">
          <button class="flex items-center gap-1 text-sm font-medium text-zinc-400 hover:text-white uppercase tracking-wider transition-colors cursor-default">
            Direttivo
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div class="absolute right-0 top-full -mt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top scale-95 group-hover:scale-100">
            <div class="bg-zinc-950 border border-white/10 rounded-2xl shadow-2xl overflow-hidden backdrop-blur-xl p-2">
              <div class="px-3 py-2 border-b border-white/5 mb-2 flex items-center justify-between">
                <span class="text-[10px] font-mono uppercase tracking-widest text-zinc-500">Rete Interna</span>
                <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.6)]" title="Richiede VPN"></span>
              </div>
              <a href="http://192.168.1.100" class="block px-3 py-2.5 text-sm text-zinc-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors">Gestione Soci</a>
              <a href="https://nextcloud-aio.tail823159.ts.net/" class="block px-3 py-2.5 text-sm text-zinc-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors">Cloud Documenti</a>
              <a href="http://admin.numen.local" class="block px-3 py-2.5 text-sm text-zinc-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors">Pannello Web</a> 
            </div>
          </div>
        </div>
      </nav>

      <div class="hidden md:flex items-center gap-4">
        <a href="/supportaci" class="text-sm font-medium text-zinc-400 hover:text-white uppercase tracking-wider transition-colors">
          Supportaci
        </a>
        <a href="/tesseramento" class="px-6 py-2.5 bg-white text-black rounded-full text-xs font-bold uppercase tracking-widest hover:bg-zinc-200 hover:scale-105 transition-all duration-300">
          Area Soci
        </a>
      </div>

      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" aria-label="Apri menu" class="text-zinc-400 hover:text-white focus:outline-none p-2">
          <svg id="icon-menu" class="w-7 h-7 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          <svg id="icon-close" class="w-7 h-7 hidden transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-zinc-950/95 backdrop-blur-xl border-b border-white/5 absolute w-full left-0 top-20 shadow-2xl overflow-y-auto max-h-[calc(100vh-5rem)]">
    <div class="px-4 pt-2 pb-6 space-y-1 flex flex-col">
      <a href="/chi-siamo" class="block px-4 py-4 text-base font-medium text-zinc-300 hover:text-white hover:bg-white/5 rounded-xl transition-colors">Chi Siamo</a>
      <a href="/eventi" class="block px-4 py-4 text-base font-medium text-zinc-300 hover:text-white hover:bg-white/5 rounded-xl transition-colors">Eventi</a>
      <a href="#progetti" class="block px-4 py-4 text-base font-medium text-zinc-300 hover:text-white hover:bg-white/5 rounded-xl transition-colors">Progetti</a>
      
      <details class="group">
        <summary class="flex justify-between items-center px-4 py-4 text-base font-medium text-zinc-400 hover:text-white cursor-pointer list-none rounded-xl hover:bg-white/5 transition-colors">
          <span class="flex items-center gap-2">
            Area Direttivo
            <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse shadow-[0_0_8px_rgba(239,68,68,0.6)]"></span>
          </span>
          <svg class="w-5 h-5 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </summary>
        <div class="pl-6 pr-4 pb-2 space-y-1 border-l border-white/10 ml-4 mt-1">
          <div class="text-[10px] font-mono uppercase tracking-widest text-zinc-600 mb-2 pl-2">Rete VPN Richiesta</div>
          <a href="http://192.168.1.100" class="block py-2.5 px-2 text-sm text-zinc-400 hover:text-white transition-colors">Gestione Soci</a>
          <a href="https://nextcloud-aio.tail823159.ts.net/" class="block py-2.5 px-2 text-sm text-zinc-400 hover:text-white transition-colors">Cloud Documenti</a>
          <a href="http://admin.numen.local" class="block py-2.5 px-2 text-sm text-zinc-400 hover:text-white transition-colors">Pannello Web</a>
        </div>
      </details>

      <a href="/supportaci" class="block px-4 py-4 text-base font-medium text-zinc-300 hover:text-white hover:bg-white/5 rounded-xl transition-colors">Supportaci</a>
      
      <div class="pt-4 mt-2 border-t border-white/10 px-4">
        <a href="/tesseramento" class="block w-full text-center px-6 py-4 bg-white text-black rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-zinc-200 transition-colors">
          Area Soci
        </a>
      </div>
    </div>
  </div>
</header>
<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    // Aggiunto btn.parentNode alla condizione di verifica
    if (btn && menu && iconMenu && iconClose && btn.parentNode) {
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);

      newBtn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        iconMenu.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');
      });
    }
  });
</script>
<style>
  /* Nasconde la freccia di default dei tag <details> su Safari/Chrome */
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>