<header class="fixed w-full top-0 z-50 bg-brand-dark/90 backdrop-blur-md border-b border-white/10 transition-all">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="flex items-center gap-3">
          <!-- Placeholder per il logo, l'utente dovrà inserire il suo logo in public/assets/logo.png -->
          <img src="/assets/numen 3.jpeg" alt="Numen APS Logo" class="h-10 w-auto object-contain invert" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAxMDAgMTAwIj48cmVjdCB3aWR0aD0iMTAwIiBoZWlnaHQ9IjEwMCIgZmlsbD0iIzIyMiIvPjx0ZXh0IHg9IjUwIiB5PSI1MCIgZm9udC1mYW1pbHk9IkFyaWFsIiBmb250LXNpemU9IjIwIiBmaWxsPSIjZmZmIiB0ZXh0LWFuY2hvcj0ibWlkZGxlIiBkeT0iLjM1ZW0iPkxvZ288L3RleHQ+PC9zdmc+'" />
          <span class="font-display font-bold text-xl tracking-wide hidden sm:block">NUMEN</span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex space-x-8">
        <a href="/chi-siamo" class="text-sm font-medium text-gray-300 hover:text-white transition-colors uppercase tracking-wider">Chi Siamo</a>
        <a href="/eventi" class="text-sm font-medium text-gray-300 hover:text-white transition-colors uppercase tracking-wider">Eventi</a>
        <a href="/matenano-kings-cup" class="text-sm font-medium text-gray-300 hover:text-white transition-colors uppercase tracking-wider">Matenano Kings Cup</a>
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center">
        <a href="/tesseramento" class="inline-flex items-center justify-center px-6 py-2.5 border border-white text-sm font-medium rounded-full text-brand-dark bg-white hover:bg-transparent hover:text-white transition-all duration-300 uppercase tracking-wider">
          Tesseramento
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex items-center md:hidden">
        <button type="button" class="text-gray-300 hover:text-white focus:outline-none" aria-label="Menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
