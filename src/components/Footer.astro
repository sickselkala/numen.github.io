---
const currentYear = new Date().getFullYear();
---
<footer class="bg-black border-t border-white/10 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
      
      <!-- Brand & Mission -->
      <div class="md:col-span-1">
        <a href="/" class="inline-block mb-6">
          <img src="/assets/logo.png" alt="Numen APS Logo" class="h-8 w-auto invert" onerror="this.style.display='none'" />
          <span class="font-display font-bold text-2xl tracking-wide">NUMEN APS</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Associazione giovanile dedicata all'innovazione, aggregazione e valorizzazione di Santa Vittoria in Matenano e del territorio marchigiano.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-wider mb-4">Esplora</h3>
        <ul class="space-y-3">
          <li><a href="/chi-siamo" class="text-gray-400 hover:text-white transition-colors text-sm">Chi Siamo</a></li>
          <li><a href="/eventi" class="text-gray-400 hover:text-white transition-colors text-sm">Eventi</a></li>
          <li><a href="/matenano-kings-cup" class="text-gray-400 hover:text-white transition-colors text-sm">Matenano Kings Cup</a></li>
        </ul>
      </div>

      <!-- Join Us -->
      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-wider mb-4">Partecipa</h3>
        <ul class="space-y-3">
          <li><a href="/tesseramento" class="text-gray-400 hover:text-white transition-colors text-sm">Diventa Socio</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors text-sm">Supporta i nostri progetti</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors text-sm">FAQ Tesseramento</a></li>
        </ul>
      </div>

      <!-- Contacts & Social -->
      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-wider mb-4">Contatti</h3>
        <ul class="space-y-3 mb-6">
          <li class="text-gray-400 text-sm">Santa Vittoria in Matenano (FM)</li>
          <li><a href="mailto:info@numenaps.it" class="text-gray-400 hover:text-white transition-colors text-sm">info@numenaps.it</a></li>
        </ul>
        <div class="flex space-x-4">
          <!-- Instagram -->
          <a href="#" class="text-gray-400 hover:text-white transition-colors">
            <span class="sr-only">Instagram</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center">
      <p class="text-xs text-gray-500 uppercase tracking-widest">
        &copy; {currentYear} Numen APS. Tutti i diritti riservati.
      </p>
      <div class="mt-4 md:mt-0 flex space-x-4">
        <a href="#" class="text-xs text-gray-500 hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="text-xs text-gray-500 hover:text-white transition-colors">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
