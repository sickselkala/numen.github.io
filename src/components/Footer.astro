<footer class="bg-black border-t border-white/10 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
      
      <div class="md:col-span-1">
        <a href="/" class="inline-block mb-6">
          <img src="/assets/logo.png" alt="Numen APS Logo" class="h-8 w-auto invert" onerror="this.style.display='none'" />
          <span class="font-display font-bold text-2xl tracking-wide">NUMEN APS</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Associazione di promozione sociale giovanile dedicata all'aggregazione e valorizzazione di Santa Vittoria in Matenano e del territorio marchigiano.
        </p>
      </div>

      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-wider mb-4">Esplora</h3>
        <ul class="space-y-3">
          <li><a href="/chi-siamo" class="text-gray-400 hover:text-white transition-colors text-sm">Chi Siamo</a></li>
          <li><a href="/eventi" class="text-gray-400 hover:text-white transition-colors text-sm">Eventi</a></li>
