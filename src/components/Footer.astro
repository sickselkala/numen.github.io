          <li><a href="/supportaci" class="text-gray-400 hover:text-white transition-colors text-sm">Supporta i nostri progetti</a></li>
          <li><a href="/tesseramento" class="text-gray-400 hover:text-white transition-colors text-sm">FAQ Tesseramento</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-display font-bold uppercase tracking-wider mb-4">Contatti</h3>
